# Database
DATABASE_URL=postgresql://user:password@host:5432/synapsite

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Admin user (used by seed script)
ADMIN_EMAIL=admin@synapsite.pl
ADMIN_PASSWORD=your-admin-password

# Contact form email
CONTACT_RECEIVER_EMAIL=your-email@example.com
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=Synapsite <noreply@synapsite.pl>

# AI Chatbot (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_MODEL=deepseek/deepseek-v3.2
